{
  "name": "rexaml",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "cross-env react-scripts start",
    "build": "cross-env react-scripts build",
    "test": "cross-env react-scripts test",
    "eject": "cross-env react-scripts eject",
    "storybook": "cross-env start-storybook -p 6006 -s public",
    "build-storybook": "cross-env build-storybook -s public",
    "styleguide": "cross-env styleguidist server",
    "styleguide:build": "cross-env styleguidist build",
    "prettier": "cross-env prettier --write",
    "lint": "cross-env eslint . --ext .js,.jsx,.ts,.tsx"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^18.19.130",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "styled-components": "^5.3.11",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "overrides": [
      {
        "files": [
          "**/*.stories.*"
        ],
        "rules": {
          "import/no-anonymous-default-export": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "packageManager": "yarn@3.3.0",
  "devDependencies": {
    "@mdx-js/react": "^1.6.22",
    "@storybook/addon-a11y": "^6.5.16",
    "@storybook/addon-actions": "^6.5.16",
    "@storybook/addon-docs": "^6.5.16",
    "@storybook/addon-essentials": "^6.5.16",
    "@storybook/addon-interactions": "^6.5.16",
    "@storybook/addon-links": "^6.5.16",
    "@storybook/builder-webpack5": "^6.5.16",
    "@storybook/manager-webpack5": "^6.5.16",
    "@storybook/node-logger": "^6.5.16",
    "@storybook/preset-create-react-app": "^4.1.2",
    "@storybook/react": "^6.5.16",
    "@storybook/testing-library": "^0.2.2",
    "@types/styled-components": "^5.1.36",
    "babel-plugin-named-exports-order": "^0.0.2",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "prop-types": "^15.8.1",
    "react-styleguidist": "^13.1.4",
    "webpack": "^5.106.2"
  }
}

